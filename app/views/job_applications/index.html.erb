<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Job Applications</h1>
  <%= link_to "Add New", new_job_application_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
</div>

<% if @job_applications.empty? %>
  <p class="text-gray-500">No applications yet. Add one!</p>
<% else %>
  <div class="space-y-3">
    <% @job_applications.each do |job| %>
      <div class="bg-white rounded-lg shadow p-5 flex justify-between items-center">
        <div>
          <h2 class="text-lg font-semibold text-gray-800"><%= job.company_name %></h2>
          <p class="text-gray-500 text-sm"><%= job.role_title %></p>
          <p class="text-xs text-gray-400 mt-1">Applied: <%= job.applied_date %></p>
        </div>
        <div class="flex items-center gap-4">
          <span class="px-3 py-1 rounded-full text-sm font-medium
            <%= job.status == 'applied' ? 'bg-blue-100 text-blue-700' :
                job.status == 'interview' ? 'bg-yellow-100 text-yellow-700' :
                job.status == 'offer' ? 'bg-green-100 text-green-700' :
                'bg-gray-100 text-gray-600' %>">
            <%= job.status %>
          </span>
          <%= link_to "View", job_application_path(job), class: "text-blue-600 text-sm hover:underline" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
