<div class="max-w-xl mx-auto bg-white rounded-lg shadow p-6">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-800"><%= @job_application.company_name %></h1>
      <p class="text-gray-500"><%= @job_application.role_title %></p>
    </div>
    <span class="px-3 py-1 rounded-full text-sm font-medium
      <%= @job_application.status == 'applied' ? 'bg-blue-100 text-blue-700' :
          @job_application.status == 'interview' ? 'bg-yellow-100 text-yellow-700' :
          @job_application.status == 'offer' ? 'bg-green-100 text-green-700' :
          'bg-red-100 text-red-600' %>">
      <%= @job_application.status %>
    </span>
  </div>

  <div class="space-y-3 text-sm text-gray-700">
    <p><span class="font-medium">Applied:</span> <%= @job_application.applied_date %></p>
    <p><span class="font-medium">URL:</span>
      <a href="<%= @job_application.job_url %>" target="_blank" class="text-blue-600 hover:underline"><%= @job_application.job_url %></a>
    </p>
    <p><span class="font-medium">Notes:</span> <%= @job_application.notes.presence || "—" %></p>
  </div>

  <div class="flex gap-4 mt-6">
    <%= link_to "Edit", edit_job_application_path(@job_application), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm" %>
    <%= link_to "Delete", job_application_path(@job_application), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 text-sm" %>
    <%= link_to "Back", job_applications_path, class: "text-blue-600 text-sm hover:underline self-center" %>
  </div>
</div>
